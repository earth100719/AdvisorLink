rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Blueprints
    function isValidGroup(data) {
      return data.keys().hasAll(['advisorId', 'members', 'classroom', 'registeredAt', 'createdBy'])
        && data.keys().size() == 5
        && data.advisorId is string && data.advisorId.size() <= 128
        && data.members is list && data.members.size() > 0 && data.members.size() <= 6
        && data.members[0] is string
        && data.classroom is string && data.classroom.size() <= 50
        && data.registeredAt is number
        && data.createdBy == request.auth.uid;
    }

    // 1. Groups Collection
    match /groups/{groupId} {
      // Rule 3: Path Variable Hardening
      allow get: if isSignedIn() && isValidId(groupId);
      allow list: if isSignedIn(); // We filter in the app, but could use resource.data.createdBy if private
      
      allow create: if isSignedIn() 
        && isValidId(groupId)
        && isValidGroup(incoming())
        && incoming().registeredAt == request.time.toMillis(); // Strict timestamp

      allow delete: if isSignedIn() 
        && existing().createdBy == request.auth.uid;
        
      // No updates allowed to groups once created for this specific app (to keep it simple & fair)
      allow update: if false;
    }

    // 2. Advisors Collection (Read-only for users)
    match /advisors/{advisorId} {
      allow read: if isSignedIn();
      allow write: if false; // Only admins or manual setup
    }
  }
}
